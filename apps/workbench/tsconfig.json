{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@taroke/core": ["../../packages/core/src/index.ts"],
      "@taroke/schema": ["../../packages/schema/src/index.ts"],
      "@taroke/artifact-runtime": ["../../packages/artifact-runtime/src/index.ts"],
      "@taroke/ui": ["../../packages/ui/src/index.ts"],
      "@taroke/fixtures": ["../../packages/fixtures/src/index.ts"]
    }
  },
  "noEmit": true,
  "include": ["src", "../../packages/*/src"],
  "exclude": ["node_modules", "dist"]
}
